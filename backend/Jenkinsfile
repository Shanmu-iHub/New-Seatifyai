pipeline {
    agent any

    environment {
        AWS_REGION = 'ap-south-1'
        ECR_REPO = 'http://864981730114.dkr.ecr.ap-south-1.amazonaws.com/sns-courseware'
        ECS_CLUSTER = 'snsihub-cluster-dev'
        ECS_SERVICE = 'sns-courseware-backend-service'
        TASK_FAMILY = 'sns-courseware-backend'
        CONTAINER_NAME = 'sns-courseware'
    }

    stages {

        stage('Clone Repository') {
            steps {
                git branch: 'main',
                url: 'https://github.com/Shanmu-iHub/New-Seatifyai.git'
            }
        }

        stage('Debug Workspace') {
            steps {
                sh '''
                echo "Current Workspace"
                pwd

                echo "Repository Files"
                ls -la

                echo "Backend Folder Files"
                ls -la backend
                '''
            }
        }

        stage('AWS ECR Login') {
            steps {
                sh '''
                aws ecr get-login-password --region $AWS_REGION | \
                docker login --username AWS --password-stdin 864981730114.dkr.ecr.ap-south-1.amazonaws.com
                '''
            }
        }

        stage('Build Docker Image From Backend Folder') {
            steps {
                dir('backend') {

                    sh '''
                    docker build -t ${ECR_REPO}:latest .
                    '''

                }
            }
        }

        stage('Push Docker Image') {
            steps {
                sh '''
                docker push ${ECR_REPO}:latest
                '''
            }
        }

        stage('Get Existing Task Definition') {
            steps {
                sh '''
                aws ecs describe-task-definition \
                --task-definition $TASK_FAMILY \
                --query taskDefinition > task-def.json
                '''
            }
        }

        stage('Create New Task Definition') {
            steps {

                sh """
                jq 'del(
                    .taskDefinitionArn,
                    .revision,
                    .status,
                    .requiresAttributes,
                    .compatibilities,
                    .registeredAt,
                    .registeredBy
                ) |
                .containerDefinitions[0].image = "${ECR_REPO}:latest"' \
                task-def.json > new-task-def.json
                """

                sh '''
                aws ecs register-task-definition \
                --cli-input-json file://new-task-def.json
                '''
            }
        }

        stage('Deploy Latest Revision') {
            steps {

                script {

                    def TASK_REVISION = sh(
                        script: """
                        aws ecs describe-task-definition \
                        --task-definition ${TASK_FAMILY} \
                        --query 'taskDefinition.revision' \
                        --output text
                        """,
                        returnStdout: true
                    ).trim()

                    echo "Latest Task Revision: ${TASK_REVISION}"

                    sh """
                    aws ecs update-service \
                    --cluster ${ECS_CLUSTER} \
                    --service ${ECS_SERVICE} \
                    --task-definition ${TASK_FAMILY}:${TASK_REVISION} \
                    --force-new-deployment
                    """
                }
            }
        }
    }

    post {

        success {
            echo '✅ Backend Deployment Successful!'
        }

        failure {
            echo '❌ Backend Deployment Failed!'
        }

        always {

            sh '''
            docker image prune -a -f || true
            docker container prune -f || true
            docker system prune -f --volumes || true
            '''
        }
    }
}